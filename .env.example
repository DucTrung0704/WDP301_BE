# ========== REDIS CONFIGURATION ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== MONGODB CONFIGURATION ==========
MONGODB_URI=mongodb://localhost:27017/utm

# ========== JWT CONFIGURATION ==========
JWT_SECRET=your-secret-key-change-in-production

# ========== CORS CONFIGURATION ==========
CORS_ORIGIN=http://localhost:3000

# ========== TELEMETRY OPTIMIZATION (Tier 1) ==========
# Enable intelligent data sampling in Worker (before DB insert)
# This reduces DB writes by 90% while keeping all data in Redis Stream for safety
TELEMETRY_SAMPLING_ENABLED=true

# Data Sampling Ratio: Store 1 out of N data points (1:10 = 90% reduction)
# Higher ratio = more aggressive sampling = less storage but fewer data points
TELEMETRY_SAMPLING_RATIO=10

# Minimum interval between stored telemetry points (milliseconds)
# Only store points if 1000ms+ has passed since last save for this drone
TELEMETRY_MIN_INTERVAL=1000

# Auto-delete telemetry records after X days (TTL)
# Set to 7 for production, can increase for longer analytics history
TELEMETRY_TTL_DAYS=7

# ========== BATCH PROCESSING (Kafka/Redis Worker) ==========
# Number of records to batch before inserting to DB
BATCH_SIZE=1000

# Maximum wait time before flushing batch to DB (milliseconds)
FLUSH_INTERVAL_MS=5000

# ========== KAFKA CONFIGURATION (if using Kafka) ==========
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=telemetry
KAFKA_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1
KAFKA_COMPRESSION=snappy

# ========== APPLICATION CONFIGURATION ==========
NODE_ENV=development
PORT=3000

# ========== GOOGLE AUTH (if applicable) ==========
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
