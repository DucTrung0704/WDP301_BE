#!/usr/bin/env node

/**
 * Module dependencies.
 */

var app = require("../app");
var debug = require("debug")("be:server");
var http = require("http");

/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || "3000");
app.set("port", port);

/**
 * Create HTTP server.
 */

var server = http.createServer(app);

/**
 * Initialize WebSocket server
 */
var websocket = require("../src/config/websocket");
websocket.init(server);

/**
 * Start mock drone simulation (global, persists to Redis)
 */
var mockDroneService = require("../src/modules/nearby/mockDroneService");
mockDroneService.startMockDroneSimulation();

/**
 * Listen on provided port, on all network interfaces.
 */

server.listen(port);
server.on("error", onError);
server.on("listening", onListening);

/**
 * Graceful shutdown handler
 */
process.on("SIGINT", async () => {
  console.log("\n📛 Received SIGINT, shutting down gracefully...");
  server.close(async () => {
    console.log("✅ HTTP server closed");

    // Shutdown websocket and Kafka
    try {
      await websocket.shutdown();
      console.log("✅ WebSocket shutdown complete");
    } catch (err) {
      console.error("Error during websocket shutdown:", err);
    }

    process.exit(0);
    // Stop mock drone simulation
    mockDroneService.stopMockDroneSimulation();

    process.exit(0);
  });

  // Force shutdown after 10 seconds
  setTimeout(() => {
    console.error("❌ Forced shutdown after timeout");
    process.exit(1);
  }, 10000);
});

process.on("SIGTERM", async () => {
  console.log("\n📛 Received SIGTERM, shutting down gracefully...");
  server.close(async () => {
    console.log("✅ HTTP server closed");

    try {
      await websocket.shutdown();
      console.log("✅ WebSocket shutdown complete");
    } catch (err) {
      console.error("Error during websocket shutdown:", err);
    }

    process.exit(0);
  });

  setTimeout(() => {
    console.error("❌ Forced shutdown after timeout");
    process.exit(1);
  }, 10000);
});

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== "listen") {
    throw error;
  }

  var bind = typeof port === "string" ? "Pipe " + port : "Port " + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case "EACCES":
      console.error(bind + " requires elevated privileges");
      process.exit(1);
      break;
    case "EADDRINUSE":
      console.error(bind + " is already in use");
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === "string" ? "pipe " + addr : "port " + addr.port;
  debug("Listening on " + bind);
}
